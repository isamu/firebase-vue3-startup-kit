  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "prettier": "^3.8.1",
    "typescript": "5.9.3"
  },
  "private": true
