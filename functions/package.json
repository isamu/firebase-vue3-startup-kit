    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "prettier": "^3.8.4",
    "typescript": "6.0.3"
  },
